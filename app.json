{
  "expo": {
    "name": "Iris.ai",
    "slug": "iris-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "iris-ai",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.irisai.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Iris.ai uses Face ID to securely access your Flow wallet — no seed phrase required.",
        "NSCameraUsageDescription": "Iris.ai uses the camera to capture scenes and describe them aloud for visually impaired users.",
        "NSMicrophoneUsageDescription": "Microphone access is required by the camera framework."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.irisai.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      "expo-camera"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
